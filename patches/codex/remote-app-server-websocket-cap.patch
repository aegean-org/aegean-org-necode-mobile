+trait JsonRpcWire: Send + 'static {
+    fn send_message<'a>(
+        &'a mut self,
+        message: JSONRPCMessage,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<()>> + Send + 'a;
+
+    fn next_message<'a>(
+        &'a mut self,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<Option<JSONRPCMessage>>> + Send + 'a;
+
+    fn close<'a>(
+        &'a mut self,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<()>> + Send + 'a;
+}
+
+struct WebSocketWire<S> {
+    stream: WebSocketStream<S>,
+}
+
+impl<S> JsonRpcWire for WebSocketWire<S>
+where
+    S: AsyncRead + AsyncWrite + Unpin + Send + 'static,
+{
+    fn send_message<'a>(
+        &'a mut self,
+        message: JSONRPCMessage,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<()>> + Send + 'a {
+        async move {
+            let payload = serde_json::to_string(&message).map_err(IoError::other)?;
+            self.stream
+                .send(Message::Text(payload.into()))
+                .await
+                .map_err(|err| {
+                    IoError::other(format!(
+                        "failed to write websocket message to `{label}`: {err}"
+                    ))
+                })
+        }
+    }
+
+    fn next_message<'a>(
+        &'a mut self,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<Option<JSONRPCMessage>>> + Send + 'a {
+        async move {
+            loop {
+                match self.stream.next().await {
+                    Some(Ok(Message::Text(text))) => {
+                        return serde_json::from_str::<JSONRPCMessage>(&text)
+                            .map(Some)
+                            .map_err(|err| {
+                                IoError::other(format!(
+                                    "remote app server at `{label}` sent invalid JSON-RPC: {err}"
+                                ))
+                            });
+                    }
+                    Some(Ok(Message::Close(frame))) => {
+                        let reason = frame
+                            .as_ref()
+                            .map(|frame| frame.reason.to_string())
+                            .filter(|reason| !reason.is_empty())
+                            .unwrap_or_else(|| "connection closed".to_string());
+                        return Err(IoError::new(
+                            ErrorKind::ConnectionAborted,
+                            format!("remote app server at `{label}` disconnected: {reason}"),
+                        ));
+                    }
+                    Some(Ok(Message::Binary(_)))
+                    | Some(Ok(Message::Ping(_)))
+                    | Some(Ok(Message::Pong(_)))
+                    | Some(Ok(Message::Frame(_))) => {}
+                    Some(Err(err)) => {
+                        return Err(IoError::other(format!(
+                            "remote app server at `{label}` transport failed: {err}"
+                        )));
+                    }
+                    None => return Ok(None),
+                }
+            }
+        }
+    }
+
+    fn close<'a>(
+        &'a mut self,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<()>> + Send + 'a {
+        async move {
+            self.stream.close(None).await.map_err(|err| {
+                IoError::other(format!(
+                    "failed to close websocket app server `{label}`: {err}"
+                ))
+            })
+        }
+    }
+}
+
+struct JsonLineWire<R, W> {
+    reader: BufReader<R>,
+    writer: W,
+}
+
+impl<R, W> JsonRpcWire for JsonLineWire<R, W>
+where
+    R: AsyncRead + Unpin + Send + 'static,
+    W: AsyncWrite + Unpin + Send + 'static,
+{
+    fn send_message<'a>(
+        &'a mut self,
+        message: JSONRPCMessage,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<()>> + Send + 'a {
+        async move {
+            let payload = serde_json::to_vec(&message).map_err(IoError::other)?;
+            self.writer.write_all(&payload).await.map_err(|err| {
+                IoError::other(format!(
+                    "failed to write JSON-lines message to `{label}`: {err}"
+                ))
+            })?;
+            self.writer.write_all(b"\n").await.map_err(|err| {
+                IoError::other(format!(
+                    "failed to finish JSON-lines message to `{label}`: {err}"
+                ))
+            })?;
+            self.writer.flush().await.map_err(|err| {
+                IoError::other(format!(
+                    "failed to flush JSON-lines message to `{label}`: {err}"
+                ))
+            })
+        }
+    }
+
+    fn next_message<'a>(
+        &'a mut self,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<Option<JSONRPCMessage>>> + Send + 'a {
+        async move {
+            let mut line = String::new();
+            let read = self.reader.read_line(&mut line).await.map_err(|err| {
+                IoError::other(format!(
+                    "failed to read JSON-lines message from `{label}`: {err}"
+                ))
+            })?;
+            if read == 0 {
+                return Ok(None);
+            }
+            serde_json::from_str::<JSONRPCMessage>(&line)
+                .map(Some)
+                .map_err(|err| {
+                    IoError::other(format!(
+                        "remote app server at `{label}` sent invalid JSON-RPC: {err}"
+                    ))
+                })
+        }
+    }
+
+    fn close<'a>(
+        &'a mut self,
+        label: &'a str,
+    ) -> impl Future<Output = IoResult<()>> + Send + 'a {
+        async move {
+            self.writer.shutdown().await.map_err(|err| {
+                IoError::other(format!(
+                    "failed to close JSON-lines app server `{label}`: {err}"
+                ))
+            })
+        }
+    }
+}
